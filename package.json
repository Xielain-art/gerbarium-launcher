{
  "name": "helioslauncher",
  "version": "2.2.3",
  "productName": "Helios Launcher",
  "description": "Modded Minecraft Launcher",
  "author": "Daniel Scalzi (https://github.com/dscalzi/)",
  "license": "UNLICENSED",
  "homepage": "https://github.com/dscalzi/HeliosLauncher",
  "bugs": {
    "url": "https://github.com/dscalzi/HeliosLauncher/issues"
  },
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build:ui": "vite build",
    "build:main": "npx esbuild src/main/handlers/*.ts --bundle --platform=node --outdir=dist/main/handlers --external:electron",
    "build:preload": "npx esbuild src/preload/preload.ts --bundle --platform=node --outfile=dist/preload/preload.js --external:electron",
    "build": "npm run build:ui && npm run build:main && npm run build:preload",
    "dist": "npm run build && electron-builder build",
    "dist:win": "npm run dist -- -w",
    "dist:mac": "npm run dist -- -m",
    "dist:linux": "npm run dist -- -l",
    "lint": "eslint .",
    "dev:ui": "vite",
    "dev:main": "npx esbuild src/main/handlers/helloHandler.ts --bundle --platform=node --outdir=dist/main/handlers --external:electron --watch",
    "dev:preload": "npx esbuild src/preload/preload.ts --bundle --platform=node --outfile=dist/preload/preload.js --external:electron --watch",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently -n \"UI,MAIN,PRELOAD,APP\" -c \"bgBlue,bgGreen,bgMagenta,bgCyan\" \"npm run dev:ui\" \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:electron\"",
    "publish-app": "npm run build && electron-builder build -p always"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "^1.168.23",
    "adm-zip": "^0.5.16",
    "discord-rpc-patch": "^4.0.1",
    "ejs": "^3.1.10",
    "ejs-electron": "^3.0.0",
    "electron-updater": "^6.7.3",
    "fs-extra": "^11.3.3",
    "github-syntax-dark": "^0.5.0",
    "got": "^11.8.5",
    "helios-core": "~2.3.0",
    "helios-distribution-types": "^1.3.0",
    "jquery": "^3.7.1",
    "lodash.merge": "^4.6.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "semver": "^7.7.3",
    "tailwindcss": "^4.2.4",
    "toml": "^3.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.3",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "wait-on": "^9.0.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dscalzi/HeliosLauncher.git"
  }
}
