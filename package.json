{
  "name": "gerbariumlauncher",
  "version": "3.0.0",
  "productName": "Gerbarium",
  "description": "Gerbarium Launcher",
  "author": "Radmir Klimau (https://github.com/Xielain-art/)",
  "license": "MIT",
  "homepage": "https://github.com/Xielain-art/gerbarium-releases",
  "bugs": {
    "url": "https://github.com/Xielain-art/gerbarium-releases/issues"
  },
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:ui": "vite build",
    "build:main": "node scripts/esbuild-main.mjs",
    "build:preload": "node scripts/esbuild-preload.mjs",
    "build": "npm run build:ui && npm run build:main && npm run build:preload",
    "dist": "npm run build && electron-builder build",
    "dist:win": "npm run dist -- -w --publish never",
    "dist:mac": "npm run dist -- -m --publish never",
    "dist:linux": "npm run dist -- -l --publish never",
    "lint": "eslint .",
    "dev:ui": "vite",
    "dev:main": "node scripts/esbuild-main.mjs --watch",
    "dev:preload": "node scripts/esbuild-preload.mjs --watch",
    "dev:electron": "electron .",
    "dev": "vite",
    "publish-app": "npm run build && electron-builder build -p always",
    "gen-types": "npx openapi-typescript https://gerbarium-api.vercel.app/api/docs-json -o ./src/lib/api/v1.d.ts",
    "test": "vitest run tests/",
    "test:unit": "vitest run tests/integrity.test.ts",
    "test:auth": "vitest run tests/auth.test.ts",
    "test:prod": "vitest run tests/production.test.ts",
    "test:integrity": "vitest run tests/integrity.test.ts",
    "test:smoke": "playwright test tests/smoke.spec.ts"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-router": "^1.168.23",
    "@types/archiver": "^7.0.0",
    "@uiw/react-md-editor": "^4.1.0",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "discord-rpc-patch": "^4.0.1",
    "dompurify": "^3.4.1",
    "ejs": "^3.1.10",
    "ejs-electron": "^3.0.0",
    "electron-log": "^5.3.3",
    "electron-updater": "^6.7.3",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.3.3",
    "github-syntax-dark": "^0.5.0",
    "got": "^11.8.5",
    "helios-core": "~2.3.0",
    "helios-distribution-types": "^1.3.0",
    "lodash.merge": "^4.6.2",
    "lucide-react": "^1.11.0",
    "marked": "^16.4.2",
    "minecraft-launcher-core": "^3.18.2",
    "openapi-fetch": "^0.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-simple-wysiwyg": "^3.4.1",
    "semver": "^7.7.3",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tar-fs": "^3.1.2",
    "toml": "^3.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "shadcn": "^4.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xielain-art/gerbarium-launcher"
  }
}