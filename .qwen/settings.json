{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(copy *)",
      "Bash(npx *)",
      "Bash(dir *)",
      "Bash(npm start)",
      "Bash(mkdir *)"
    ]
  },
  "modelProviders": {
    "gemini": [
      {
        "id": "gemini-3.1-flash-lite-preview",
        "name": "Gemini 3.1 Flash lite",
        "envKey": "GEMINI_API_KEY",
        "baseUrl": "https://generativelanguage.googleapis.com",
        "capabilities": {
          "vision": true
        },
        "generationConfig": {
          "timeout": 60000,
          "maxRetries": 2,
          "contextWindowSize": 1000000,
          "schemaCompliance": "auto",
          "samplingParams": {
            "temperature": 0.4,
            "top_p": 0.95,
            "max_tokens": 8192,
            "top_k": 40
          }
        }
      }
    ]
  },
  "$version": 3,
  "model": {
    "name": "gemini-3.1-flash-lite-preview"
  },
  "security": {
    "auth": {
      "selectedType": "gemini"
    }
  }
}